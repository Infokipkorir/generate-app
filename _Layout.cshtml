<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Letter Generator</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <a class="brand" href="/">✉ LetterGen AI</a>
            <a class="nav-link" href="/">New Letter</a>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer>
        <p>Powered by Claude AI · LetterGen</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
